{
  "name": "sortlist-max-cli",
  "version": "1.5.2",
  "description": "Max CLI - Command line interface for the Max lead intelligence API. Discover leads, manage subscriptions, and automate workflows from the terminal or AI agents.",
  "main": "dist/index.js",
  "bin": {
    "max": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node ./dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "keywords": [
    "signals",
    "cli",
    "leads",
    "lead-generation",
    "sales-intelligence",
    "automation",
    "ai-agent",
    "claude-code",
    "openclaw",
    "clawhub",
    "command-line"
  ],
  "author": "Sortlist",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sortlist/max-cli.git"
  },
  "homepage": "https://github.com/sortlist/max-cli#readme",
  "bugs": {
    "url": "https://github.com/sortlist/max-cli/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/yargs": "^17.0.32",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3"
  }
